SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ONEMAP_EMAIL=
ONEMAP_PASSWORD=
LTA_API_KEY=
GEMINI_API_KEY=
OPENWEATHER_API_KEY=
FRONTEND_URL=
UNSPLASH_ACCESS_KEY=

# Optional: Pexels API — used only by scripts/seed_images_pexels.py (not used at runtime)
# Get free key: https://www.pexels.com/api/  (200 req/hr, 20 000 req/month on free tier)
PEXELS_API_KEY=

# Optional: Google Places API (New) — used only by scripts/enrich_places_google.py
# Get key: https://console.cloud.google.com → APIs & Services → Credentials
# Enable API: Maps Platform → Places API (New)
GOOGLE_PLACES_API_KEY=

# ── Chatbot LLM ───────────────────────────────────────────────────────────────
# api_key mode (default): set GEMINI_API_KEY above and leave GOOGLE_GENAI_USE_VERTEXAI=false.
# Vertex mode: set GOOGLE_GENAI_USE_VERTEXAI=true + the project/location/credentials below;
# then GEMINI_API_KEY may be left empty (the 15-RPM rate-limit guard is skipped on Vertex).
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
CHAT_MODEL=gemini-2.5-flash
